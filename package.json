{
  "name": "ecommerce-app-angular-21-migration",
  "version": "21.0.0",
  "private": true,
  "description": "Angular 21 migration of the legacy Trend Shopping ecommerce demo.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "start:migrated": "ng serve --host 0.0.0.0 --port 4200",
    "start:legacy": "npx --yes http-server legacy-angular-6/dist/demo -a 0.0.0.0 -p 4206 -c-1 -P http://localhost:4206?",
    "build:legacy": "cd legacy-angular-6 && npm install --legacy-peer-deps && set NODE_OPTIONS=--openssl-legacy-provider&& npm run build -- --aot",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless"
  },
  "dependencies": {
    "@angular/animations": "21.2.15",
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "@angular/platform-browser-dynamic": "21.2.15",
    "@angular/router": "21.2.15",
    "bootstrap": "4.6.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.15",
    "@types/jasmine": "~5.1.9",
    "@types/node": "^24.10.1",
    "http-server": "^14.1.1",
    "jasmine-core": "~5.12.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
